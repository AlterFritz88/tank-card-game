                      scale: 0.22,
                    }}
                    animate={{
                      x: projectileEffect.to.x - projectileEffect.from.x,
                      y: projectileEffect.to.y - projectileEffect.from.y,
                      opacity: [0, 1, 1, 0],
                      scale: [0.22, 0.28, 0.28, 0.22],
