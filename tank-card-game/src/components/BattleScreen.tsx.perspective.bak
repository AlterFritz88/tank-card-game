    <div style={styles.enemyHandCardMask}>
     {battle[opponentPlayerId].hand.map((cardInstance, index) => (
  <div
    key={`bot-hand-${cardInstance.instanceId}`}
    ref={setHandCardRef("bot", cardInstance.instanceId)}
