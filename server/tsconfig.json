{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../tank-card-game/src/game/cards.ts",
    "../tank-card-game/src/game/engine.ts",
    "../tank-card-game/src/game/initialState.ts",
    "../tank-card-game/src/game/types.ts"
  ]
}
