PORT=8787

# Browser origins allowed to connect to the WebSocket server.
# Replace this with the real frontend URL after deploying the client.
WS_ALLOWED_ORIGINS=https://your-frontend.example.com

# Use persistent storage on the hosting provider.
# Render example with a mounted disk:
# PLAYER_PROFILE_DB_PATH=/var/data/player-profiles.json
# PLAYER_ACCOUNT_DB_PATH=/var/data/player-accounts.json
PLAYER_PROFILE_DB_PATH=/persistent/player-profiles.json
PLAYER_ACCOUNT_DB_PATH=/persistent/player-accounts.json

PVP_RECONNECT_GRACE_MS=15000
# Matchmaking weight band: ±15% of deck weight, widening +10pp every 5s up to 30s.
PVP_MATCH_BASE_TOLERANCE_PCT=15
PVP_MATCH_TOLERANCE_STEP_PCT=10
PVP_MATCH_TOLERANCE_STEP_MS=5000
PVP_MATCH_TOLERANCE_MAX_MS=30000
PVP_MATCH_SWEEP_INTERVAL_MS=1000

WS_MAX_MESSAGE_BYTES=262144
WS_RATE_LIMIT_WINDOW_MS=1000
WS_RATE_LIMIT_MAX_MESSAGES=60
WS_RATE_LIMIT_BLOCK_MS=2000

# Per-IP guards (aggregate across all sockets from one IP).
WS_MAX_CONNECTIONS_PER_IP=30
WS_IP_RATE_LIMIT_WINDOW_MS=1000
WS_IP_RATE_LIMIT_MAX_MESSAGES=240
WS_IP_RATE_LIMIT_BLOCK_MS=5000

# Login brute-force protection (per IP).
LOGIN_MAX_FAILED_ATTEMPTS=10
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_BLOCK_MS=900000
