PORT=8787
# Optional. Leave empty on most PaaS hosts so Node binds to the default interface.
# For local LAN testing you can use HOST=0.0.0.0
HOST=

# Optional persistent storage path. New installs should use SQLite.
PANZERSHREK_DB_PATH=./data/panzershrek.sqlite

# Legacy JSON paths are still read once for automatic migration into SQLite.
PLAYER_PROFILE_DB_PATH=./data/player-profiles.json
PLAYER_ACCOUNT_DB_PATH=./data/player-accounts.json

# Master/play accounts: comma-separated logins that get every headquarters and
# the full card collection unlocked. Regular players still unlock everything
# beyond the three training headquarters through progression.
# Example: MASTER_ACCOUNT_USERNAMES=commander,tester
MASTER_ACCOUNT_USERNAMES=

# Comma-separated browser origins allowed to open WebSocket connections.
# Production example: WS_ALLOWED_ORIGINS=https://your-frontend.example.com
# Leave empty only for local/private testing.
WS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# PVP tuning.
PVP_RECONNECT_GRACE_MS=15000
# Matchmaking weight band: starts at ±15% of deck weight and widens by +10pp
# every 5s, capped at 30s of waiting.
PVP_MATCH_BASE_TOLERANCE_PCT=15
PVP_MATCH_TOLERANCE_STEP_PCT=10
PVP_MATCH_TOLERANCE_STEP_MS=5000
PVP_MATCH_TOLERANCE_MAX_MS=30000
PVP_MATCH_SWEEP_INTERVAL_MS=1000

# Basic WebSocket abuse guards.
WS_MAX_MESSAGE_BYTES=262144
WS_RATE_LIMIT_WINDOW_MS=1000
WS_RATE_LIMIT_MAX_MESSAGES=60
WS_RATE_LIMIT_BLOCK_MS=2000

# Per-IP guards (aggregate across all sockets from one IP — the per-socket
# limits above are bypassable by opening many connections).
WS_MAX_CONNECTIONS_PER_IP=30
WS_IP_RATE_LIMIT_WINDOW_MS=1000
WS_IP_RATE_LIMIT_MAX_MESSAGES=240
WS_IP_RATE_LIMIT_BLOCK_MS=5000

# Login brute-force protection (per IP).
LOGIN_MAX_FAILED_ATTEMPTS=10
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_BLOCK_MS=900000
